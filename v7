function getPool() {
    let p = PHRASES.filter(x => x.cat === S.cat && x.type === S.type);
    if (S.cat === 'romance' && S.type === 'Questions profondes' && S.themes.length > 0) p = p.filter(x => S.themes.includes(x.th));
    const cfg = CAT_CFG[S.cat];
    if (!cfg.levels) return p;
    if (S.level === -1) return p;
    if (S.cat === 'jeux') return p.filter(x => x.lv <= S.level && x.lv >= 1);
    return p.filter(x => x.lv <= S.level);
}
function generate() {
    if (credits <= 0) { showLimit(); return; }
    let pool = getPool();
    let toned = S.tones.length > 0 ? pool.filter(p => S.tones.includes(p.ton)) : pool;
    if (toned.length === 0) toned = pool;
    if (toned.length === 0) { toast('Pas assez de phrases pour cette combinaison.', 3000); return; }
    credits--; saveCredits();
    S.results = S.level === -1 ? pickMixed(toned, 4) : pickRandom(toned, 4);
    renderResults();
    nav('results');
}
function reroll() {
    let pool = getPool();
    let toned = S.tones.length > 0 ? pool.filter(p => S.tones.includes(p.ton)) : pool;
    if (toned.length === 0) toned = pool;
    if (toned.length === 0) return;
    let fresh = toned.filter(p => !S.results.some(r => r.id === p.id));
    if (fresh.length < 4) fresh = toned;
    S.results = S.level === -1 ? pickMixed(fresh, 4) : pickRandom(fresh, 4);
    renderResults(true);
}
function pickRandom(arr, n) { return [...arr].sort(() => Math.random() - .5).slice(0, Math.min(n, arr.length)); }
function pickMixed(pool, n) {
    const byLv = {}; pool.forEach(p => { if (!byLv[p.lv]) byLv[p.lv] = []; byLv[p.lv].push(p); });
    Object.keys(byLv).forEach(k => { byLv[k] = [...byLv[k]].sort(() => Math.random() - .5); });
    const lvKeys = Object.keys(byLv).sort();
    const result = []; let i = 0, tries = 0;
    while (result.length < n && tries < n * 10) {
        tries++;
        const lv = lvKeys[i % lvKeys.length];
        if (byLv[lv] && byLv[lv].length > 0) result.push(byLv[lv].shift());
        i++;
        if (Object.values(byLv).every(a => a.length === 0)) break;
    }
    if (result.length < n) { const rem = pool.filter(p => !result.includes(p)); result.push(...pickRandom(rem, n - result.length)); }
    return result.slice(0, n);
}

