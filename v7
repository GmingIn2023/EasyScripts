<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, viewport-fit=cover">
    <title>EasyScripts — Toujours les bons mots</title>
    <meta name="description" content="Génère des scripts prêts à copier pour Romance, Jeux, Travail et Administratif. Même sans inspiration.">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;1,9..144,300;1,9..144,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #f4ede3; --cream2: #ede4d6; --paper: #faf6f0; --ink: #1e1812; --ink2: #3a3028;
            --muted: #9a8f82; --border: #d9cfc3; --border2: #c8bdb0;
            --romance: #b85c38; --romance-bg: #f7ede7; --romance-border: #ddb8a6;
            --jeux: #4a7c59; --jeux-bg: #eaf2ec; --jeux-border: #a8ccb2;
            --travail: #3d6b8f; --travail-bg: #e8f0f7; --travail-border: #a4bed3;
            --admin: #7a5c2e; --admin-bg: #f5ede0; --admin-border: #c9a97a;
            --pro-gold: #c98c2c; --pro-bg: #fffbf0; --pro-border: #e8c573;
            --r: 10px; --r-lg: 16px; --r-xl: 22px;
            --sh: 0 2px 8px rgba(30,24,18,.07),0 6px 24px rgba(30,24,18,.05);
            --sh-lift: 0 6px 20px rgba(30,24,18,.13),0 14px 48px rgba(30,24,18,.09);
            --max-w: 920px; --text-w: 620px;
        }
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        html,body{font-family:'Outfit',sans-serif;background:var(--cream);color:var(--ink);min-height:100vh;font-size:15px;line-height:1.55;overflow-x:hidden;-webkit-font-smoothing:antialiased}
        body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");pointer-events:none;z-index:0;opacity:.5}
        .container{width:100%;max-width:var(--max-w);margin:0 auto;position:relative;z-index:1}
        #splash{position:fixed;inset:0;background:var(--paper);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;transition:opacity .4s}
        #splash.hidden{opacity:0;pointer-events:none}
        .splash-logo{font-family:'Fraunces',serif;font-size:32px;font-weight:500;color:var(--ink);letter-spacing:-.5px}
        .splash-logo em{font-style:italic;color:var(--romance)}
        .splash-bar{width:160px;height:4px;background:var(--border);border-radius:4px;overflow:hidden}
        .splash-fill{height:100%;background:linear-gradient(90deg,var(--romance),var(--jeux));border-radius:4px;width:0%;transition:width .3s ease}
        .splash-txt{font-size:12px;color:var(--muted);text-align:center}
        .splash-err{font-size:12px;color:var(--romance);text-align:center;max-width:280px;display:none}
        .splash-retry{margin-top:4px;padding:9px 20px;background:var(--ink);color:var(--cream);border:none;border-radius:8px;font-size:13px;cursor:pointer;font-family:'Outfit',sans-serif;display:none}
        .topbar{display:flex;align-items:center;justify-content:space-between;padding:14px 20px 12px;border-bottom:1px solid var(--border);background:rgba(250,246,240,.96);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);position:sticky;top:0;z-index:100}
        .topbar-inner{display:flex;align-items:center;justify-content:space-between;width:100%;max-width:var(--max-w);margin:0 auto}
        .logo{font-family:'Fraunces',serif;font-size:20px;font-weight:500;color:var(--ink);letter-spacing:-.5px;cursor:pointer;user-select:none;flex-shrink:0}
        .logo em{font-style:italic;color:var(--romance)}
        .topbar-r{display:flex;align-items:center;gap:9px;flex-shrink:0}
        .cred-badge{display:flex;align-items:center;gap:5px;background:var(--cream2);border:1px solid var(--border);border-radius:30px;padding:5px 12px 5px 8px;font-size:12px;font-weight:600;color:var(--ink2);cursor:pointer;transition:all .15s}
        .cred-badge:hover{background:var(--border)}
        .dots-row{display:flex;gap:3px}
        .dot{width:5px;height:5px;border-radius:50%;background:var(--border2)}
        .dot.on{background:var(--jeux)}
        .icon-btn{width:34px;height:34px;border-radius:var(--r);border:1px solid var(--border);background:var(--paper);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;color:var(--ink2);transition:all .15s;position:relative;flex-shrink:0}
        .icon-btn:hover{background:var(--cream2)}
        .user-avatar{width:28px;height:28px;border-radius:50%;background:var(--cream2);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--ink2);overflow:hidden;flex-shrink:0}
        .user-avatar img{width:100%;height:100%;object-fit:cover}
        .pro-chip{display:inline-flex;align-items:center;gap:3px;background:var(--pro-bg);border:1px solid var(--pro-border);color:var(--pro-gold);font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;letter-spacing:.04em}
        .signin-btn{background:var(--ink);color:var(--cream);border:none;border-radius:20px;padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;transition:opacity .15s;white-space:nowrap}
        .signin-btn:hover{opacity:.85}
        .page{display:none;min-height:100vh;position:relative;z-index:1;animation:pageIn .3s ease}
        .page.active{display:block}
        @keyframes pageIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
        .home-hero{background:var(--paper);border-bottom:1px solid var(--border);padding:36px 22px 32px;text-align:center}
        .home-hero-inner{max-width:var(--text-w);margin:0 auto}
        .home-tagline{font-family:'Fraunces',serif;font-size:clamp(28px,5vw,38px);font-weight:500;line-height:1.12;letter-spacing:-.6px;margin-bottom:18px;text-wrap:balance}
        .home-tagline em{font-style:italic;color:var(--romance)}
        .home-desc{font-size:14.5px;color:var(--ink2);line-height:1.8;margin-bottom:22px;text-wrap:pretty;max-width:560px;margin-left:auto;margin-right:auto}
        .home-desc strong{color:var(--ink)}
        .home-howto{background:var(--cream2);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px;text-align:left;max-width:480px;margin:0 auto}
        .howto-title{font-family:'Fraunces',serif;font-size:13px;font-weight:500;font-style:italic;color:var(--ink2);margin-bottom:12px}
        .howto-step{display:flex;align-items:flex-start;gap:11px;font-size:13px;color:var(--ink2);margin-bottom:9px;line-height:1.55}
        .howto-step:last-child{margin-bottom:0}
        .howto-num{width:22px;height:22px;border-radius:50%;background:var(--ink);color:var(--cream);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
        .db-status{text-align:center;padding:8px;font-size:11px;font-weight:600;display:none;max-width:var(--max-w);margin:0 auto}
        .db-status.live{color:var(--jeux);display:block}
        .db-status.cache{color:var(--muted);display:block}
        .sec-div{padding:22px 20px 10px;display:flex;align-items:center;gap:12px;max-width:var(--max-w);margin:0 auto}
        .sec-div-txt{font-family:'Fraunces',serif;font-size:11px;font-weight:500;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);white-space:nowrap}
        .sec-div-line{flex:1;height:1px;background:var(--border)}
        .cat-grid{padding:0 14px 14px;display:grid;grid-template-columns:1fr;gap:10px;max-width:var(--max-w);margin:0 auto}
        @media(min-width:640px){.cat-grid{grid-template-columns:1fr 1fr;padding:0 18px 18px;gap:14px}}
        .cat-card{background:var(--paper);border:1px solid var(--border);border-radius:var(--r-xl);padding:18px 16px;cursor:pointer;display:flex;align-items:center;gap:14px;box-shadow:var(--sh);transition:all .22s;position:relative;overflow:hidden}
        .cat-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:5px}
        .cat-card.romance::before{background:linear-gradient(180deg,#d4845a,var(--romance))}
        .cat-card.jeux::before{background:linear-gradient(180deg,#6aad7e,var(--jeux))}
        .cat-card.travail::before{background:linear-gradient(180deg,#5a8fb8,var(--travail))}
        .cat-card.admin::before{background:linear-gradient(180deg,#a07d4a,var(--admin))}
        .cat-card:active{transform:scale(.98)}.cat-card:hover{box-shadow:var(--sh-lift);transform:translateY(-2px)}
        .cat-card.romance:hover{border-color:var(--romance-border)}.cat-card.jeux:hover{border-color:var(--jeux-border)}.cat-card.travail:hover{border-color:var(--travail-border)}.cat-card.admin:hover{border-color:var(--admin-border)}
        .cat-card.locked{opacity:.55;pointer-events:none;filter:grayscale(.3)}
        .cat-icon{width:46px;height:46px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
        .cat-card.romance .cat-icon{background:var(--romance-bg)}.cat-card.jeux .cat-icon{background:var(--jeux-bg)}.cat-card.travail .cat-icon{background:var(--travail-bg)}.cat-card.admin .cat-icon{background:var(--admin-bg)}
        .cat-info{flex:1;min-width:0}
        .cat-name{font-family:'Fraunces',serif;font-size:17px;font-weight:500;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .cat-sub{font-size:11.5px;color:var(--muted);line-height:1.4}
        .cat-count{font-size:10px;font-weight:700;color:var(--muted);margin-top:3px}
        .cat-arrow{width:28px;height:28px;border-radius:50%;background:var(--cream2);display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--muted);flex-shrink:0;font-weight:600}
        .pro-badge{position:absolute;top:10px;right:13px;background:var(--pro-bg);border:1px solid var(--pro-border);color:var(--pro-gold);font-size:9px;font-weight:700;letter-spacing:.09em;padding:2px 7px;border-radius:5px;text-transform:uppercase;z-index:2}
        .home-bottom{padding:0 14px 30px;text-align:center;max-width:var(--max-w);margin:0 auto}
        .home-about-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:transparent;border:1px dashed var(--border2);border-radius:var(--r-xl);font-size:13px;color:var(--muted);cursor:pointer;font-family:'Outfit',sans-serif;transition:background .15s;text-decoration:none}
        .home-about-btn:hover{background:var(--cream2)}
        .ad-banner{max-width:var(--max-w);margin:12px auto;padding:0 14px;display:flex;justify-content:center}
        .ad-slot{width:100%;max-width:728px;min-height:50px;background:var(--paper);border:1px dashed var(--border2);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--muted);letter-spacing:.04em;cursor:default;transition:border-color .2s;text-align:center;padding:8px}
        .ad-slot:hover{border-color:var(--border)}@media(min-width:640px){.ad-slot{min-height:60px}}
        .back-row{display:flex;align-items:center;gap:7px;padding:14px 20px 0;font-size:13px;color:var(--muted);cursor:pointer;width:fit-content;max-width:var(--max-w);margin:0 auto}
        .back-row:hover{color:var(--ink)}
        .cat-hero{background:var(--paper);border-bottom:1px solid var(--border);padding:14px 20px 20px;max-width:var(--max-w);margin:0 auto}
        .cat-badge{display:inline-flex;align-items:center;gap:7px;padding:5px 13px 5px 9px;border-radius:30px;border:1px solid;font-size:12px;font-weight:600;margin-bottom:10px}
        .cat-hero-title{font-family:'Fraunces',serif;font-size:23px;font-weight:500;letter-spacing:-.4px;line-height:1.2}
        .tabs{display:flex;border-bottom:1px solid var(--border);background:var(--paper);padding:0 20px;position:sticky;top:52px;z-index:90;max-width:var(--max-w);margin:0 auto}
        .tab-btn{padding:11px 18px;font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;margin-bottom:-1px}
        .tab-btn.active{color:var(--ink);border-bottom-color:var(--ink)}
        .tab-pane{display:none;padding-bottom:20px;max-width:var(--max-w);margin:0 auto}.tab-pane.active{display:block}
        .fsec{padding:16px 18px 0}
        .flabel{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:11px;display:flex;align-items:center;gap:6px}
        .flabel-step{width:18px;height:18px;border-radius:50%;background:var(--ink);color:var(--cream);font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .type-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}@media(min-width:640px){.type-grid{grid-template-columns:repeat(4,1fr)}}
        .type-card{background:var(--paper);border:2px solid var(--border);border-radius:var(--r-lg);padding:14px 10px;cursor:pointer;transition:all .15s;text-align:center}
        .type-card:active{transform:scale(.96)}.type-card.sel-romance{background:var(--romance-bg);border-color:var(--romance)}.type-card.sel-jeux{background:var(--jeux-bg);border-color:var(--jeux)}.type-card.sel-travail{background:var(--travail-bg);border-color:var(--travail)}.type-card.sel-admin{background:var(--admin-bg);border-color:var(--admin)}
        .type-card .tc-emoji{font-size:22px;margin-bottom:5px}.type-card .tc-name{font-size:12px;font-weight:600;color:var(--ink2);line-height:1.3}.type-card .tc-count{font-size:10px;color:var(--muted);margin-top:2px}.type-card.unavail{opacity:.35;pointer-events:none}
        .theme-scroll{display:flex;gap:7px;overflow-x:auto;padding:4px 2px 8px;scrollbar-width:none;flex-wrap:wrap}.theme-scroll::-webkit-scrollbar{display:none}
        .theme-pill{display:flex;align-items:center;gap:6px;padding:8px 14px;border-radius:30px;border:2px solid var(--border);background:var(--paper);font-size:12px;font-weight:600;color:var(--ink2);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0}.theme-pill:active{transform:scale(.95)}.theme-pill.sel{border-color:var(--romance);background:var(--romance-bg);color:var(--romance)}
        .theme-hint{font-size:11px;color:var(--muted);margin-top:3px}
        .tag-row{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:4px}
        .tag{background:var(--paper);border:2px solid var(--border);border-radius:30px;padding:8px 16px;font-size:13px;font-weight:500;color:var(--ink2);cursor:pointer;transition:all .15s;user-select:none}.tag:active{transform:scale(.95)}.tag:hover{border-color:var(--border2);background:var(--cream2)}.tag.sel-romance{background:var(--romance-bg);border-color:var(--romance);color:var(--romance)}.tag.sel-jeux{background:var(--jeux-bg);border-color:var(--jeux);color:var(--jeux)}.tag.sel-travail{background:var(--travail-bg);border-color:var(--travail);color:var(--travail)}.tag.sel-admin{background:var(--admin-bg);border-color:var(--admin);color:var(--admin)}.tag.unavail{opacity:.3;pointer-events:none;text-decoration:line-through}
        .tag-hint{font-size:11px;color:var(--muted);margin-top:4px}
        .lv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:7px}
        .lv-card{border:2px solid var(--border);border-radius:var(--r-lg);padding:12px 6px;cursor:pointer;background:var(--paper);text-align:center;transition:all .15s}.lv-card:active{transform:scale(.95)}.lv-card .lv-emoji{font-size:20px;margin-bottom:4px}.lv-card .lv-name{font-size:10px;font-weight:700;color:var(--muted)}.lv-card .lv-count{font-size:9px;color:var(--muted);margin-top:2px}
        .lv-card.active-s{background:var(--jeux-bg);border-color:var(--jeux)}.lv-card.active-s .lv-name{color:var(--jeux)}.lv-card.active-m{background:#fff8e8;border-color:#d4a843}.lv-card.active-m .lv-name{color:#7a5c00}.lv-card.active-h{background:#ffeaea;border-color:#c0392b}.lv-card.active-h .lv-name{color:#c0392b}.lv-card.active-all{background:var(--ink);border-color:var(--ink)}.lv-card.active-all .lv-name,.lv-card.active-all .lv-emoji,.lv-card.active-all .lv-count{color:var(--cream)}
        .warn-adult{display:none;margin:10px 18px 0;background:#fff3cd;border:1px solid #ffc107;border-radius:10px;padding:10px 13px;font-size:12px;color:#5c3e00;line-height:1.5}.warn-adult.show{display:block}
        .gen-wrap{padding:18px 18px 30px;text-align:center}
        .cred-strip{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:15px;flex-wrap:wrap}
        .mini-dots-wrap{display:flex;gap:2px}.mini-dot{width:6px;height:6px;border-radius:50%;background:var(--border)}.mini-dot.on{background:var(--jeux)}.cred-txt{font-size:11px;color:var(--muted);font-weight:500}
        .gen-btn{display:inline-block;width:100%;max-width:400px;padding:17px 24px;border-radius:var(--r-lg);border:none;font-family:'Fraunces',serif;font-size:18px;font-weight:500;font-style:italic;cursor:pointer;transition:all .22s;text-align:center;position:relative;overflow:hidden;color:#fff}.gen-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.12) 0%,transparent 100%)}.gen-btn.romance{background:linear-gradient(135deg,#c96b45,var(--romance))}.gen-btn.jeux{background:linear-gradient(135deg,#5a9c6e,var(--jeux))}.gen-btn.travail{background:linear-gradient(135deg,#4d80a8,var(--travail))}.gen-btn.admin{background:linear-gradient(135deg,#9a7240,var(--admin))}.gen-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(30,24,18,.25)}.gen-btn:active{transform:scale(.97)}
        .tips-list{padding:14px}.tip-item{background:var(--paper);border:1px solid var(--border);border-radius:var(--r-lg);margin-bottom:9px;overflow:hidden;box-shadow:var(--sh)}.tip-hdr{padding:15px 16px;cursor:pointer;display:flex;align-items:center;gap:11px}.tip-num{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;color:#fff}.tip-hdr-text{flex:1;min-width:0}.tip-hdr-title{font-family:'Fraunces',serif;font-size:15px;font-weight:500;margin-bottom:2px}.tip-hdr-preview{font-size:11px;color:var(--muted);font-style:italic;line-height:1.4}.tip-arr{font-size:14px;color:var(--muted);transition:transform .2s;flex-shrink:0}.tip-item.open .tip-arr{transform:rotate(90deg)}.tip-body{display:none;padding:13px 16px 15px;font-size:13px;color:var(--ink2);line-height:1.85;border-top:1px solid var(--border)}.tip-item.open .tip-body{display:block}
        .results-hdr{background:var(--paper);border-bottom:1px solid var(--border);padding:14px 20px;max-width:var(--max-w);margin:0 auto}.results-bc{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:4px;flex-wrap:wrap;margin-bottom:5px}.results-title{font-family:'Fraunces',serif;font-size:22px;font-weight:500;font-style:italic;letter-spacing:-.3px}
        .filter-summary{margin:10px 14px 0;background:var(--paper);border:1px solid var(--border);border-radius:var(--r-lg);padding:13px 15px;box-shadow:var(--sh);font-size:12px;max-width:var(--max-w);margin-left:auto;margin-right:auto}.fs-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-bottom:5px}.fs-row:last-child{margin-bottom:0}.fs-chip{display:inline-flex;align-items:center;gap:4px;padding:4px 11px;border-radius:20px;font-size:11px;font-weight:700;border:1px solid}.fs-label{font-size:10px;color:var(--muted);font-weight:500}.tone-dist{font-size:11px;color:var(--muted);margin-top:5px;padding-top:6px;border-top:1px solid var(--border);line-height:1.6}.tone-dist strong{color:var(--ink2)}
