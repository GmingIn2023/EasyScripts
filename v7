        updateCounts(); renderAdminBody();
        toast(active ? '✓ Phrase réactivée' : '✓ Phrase désactivée');
    } catch (e) { toast('Erreur : ' + e.message); }
}
function renderAdminTips(body) {
    body.appendChild(catSelector());
    const cat = adminCat, tips = TIPS[cat] || [];
    const add = document.createElement('div'); add.className = 'admin-sec';
    add.innerHTML = `<h4>+ Ajouter un conseil</h4><input class="admin-in" id="nt-t" placeholder="Titre" style="height:36px;resize:none"><input class="admin-in" id="nt-p" placeholder="Aperçu (1 ligne)" style="height:36px;resize:none"><textarea class="admin-in" id="nt-b" placeholder="Corps du conseil" style="min-height:70px"></textarea><button class="admin-save" onclick="addTip('${cat}')">Ajouter</button>`;
    body.appendChild(add);
    tips.forEach((tip, i) => {
        const s = document.createElement('div'); s.className = 'admin-sec';
        s.innerHTML = `<h4>#${i + 1} — ${tip.title}</h4><input class="admin-in" id="et-t-${i}" value="${tip.title.replace(/"/g, '&quot;')}" style="height:36px;resize:none"><input class="admin-in" id="et-p-${i}" value="${tip.preview.replace(/"/g, '&quot;')}" style="height:36px;resize:none"><textarea class="admin-in" id="et-b-${i}" style="min-height:70px">${tip.body}</textarea><div class="admin-row"><button class="admin-save" onclick="updateTip('${cat}',${i})">✓ Sauvegarder</button><button class="admin-del" onclick="deleteTip('${cat}',${i})">✕ Supprimer</button></div>`;
        body.appendChild(s);
    });
}
function addTip(cat) { const t = document.getElementById('nt-t').value.trim(), p = document.getElementById('nt-p').value.trim(), b = document.getElementById('nt-b').value.trim(); if (!t || !b) { toast('Titre et corps requis.'); return; } TIPS[cat].push({ title: t, preview: p, body: b }); localStorage.setItem('es_tips', JSON.stringify(TIPS)); renderAdminBody(); }
function updateTip(cat, i) { TIPS[cat][i].title = document.getElementById('et-t-' + i).value.trim(); TIPS[cat][i].preview = document.getElementById('et-p-' + i).value.trim(); TIPS[cat][i].body = document.getElementById('et-b-' + i).value.trim(); localStorage.setItem('es_tips', JSON.stringify(TIPS)); toast('✓ Conseil mis à jour'); }
function deleteTip(cat, i) { if (!confirm('Supprimer ?')) return; TIPS[cat].splice(i, 1); localStorage.setItem('es_tips', JSON.stringify(TIPS)); renderAdminBody(); }

