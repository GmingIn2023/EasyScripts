    ['home','cat','results'].forEach(id => {
        const dr = document.getElementById('dots-' + id), tx = document.getElementById('ctxt-' + id);
        if (!dr) return;
        dr.innerHTML = '';
        const totalDots = Math.min(max, 20);
        const onDots = Math.round(pct * totalDots);
        for (let i = 0; i < totalDots; i++) {
            const d = document.createElement('div');
            d.className = 'dot' + (i < onDots ? ' on' : '');
            dr.appendChild(d);
        }
        if (tx) tx.textContent = credits + (max > 20 ? ' Pro' : '');
    });
    const mini = document.getElementById('dots-gen-mini'), sm = document.getElementById('cred-gen-text');
    if (mini) {
        mini.innerHTML = '';
        const show = Math.min(max, 40);
        for (let i = 0; i < show; i++) {
            const d = document.createElement('div');
            d.className = 'mini-dot' + (i < credits ? ' on' : '');
            mini.appendChild(d);
        }
    }
